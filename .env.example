# ========================================
# LocalLoyal - Environment Configuration
# ========================================

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/localloyal
MONGODB_TEST_URI=mongodb://localhost:27017/localloyal_test

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# WhatsApp/Twilio Integration
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Application Configuration
APP_NAME=LocalLoyal
APP_URL=https://your-app.vercel.app
APP_PORT=3000
APP_ENV=development

# Firebase Configuration (if using)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcwggSjAgEAAoIBAQC...\n-----END PRIVATE KEY-----\n
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# Razorpay Payment Gateway (if using payments)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_key_here

# Email Configuration (if using)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here

# SMS Configuration (if using SMS instead of WhatsApp)
SMS_API_KEY=your_sms_api_key
SMS_SENDER_ID=LOCALLOYAL

# Redis Configuration (for caching)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password

# File Upload Configuration
UPLOAD_MAX_SIZE=5242880
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,pdf

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100

# Analytics & Monitoring
GOOGLE_ANALYTICS_ID=GA-XXXXXXXX-X
SENTRY_DSN=https://your-sentry-dsn-here

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Security
CORS_ORIGIN=https://your-app.vercel.app
BCRYPT_ROUNDS=12

# Development Settings
DEBUG_MODE=true
ENABLE_SWAGGER=true
MOCK_WHATSAPP=false

# Production Settings (uncomment for production)
# APP_ENV=production
# DEBUG_MODE=false
# ENABLE_SWAGGER=false
# LOG_LEVEL=error

# ========================================
# API Endpoints
# ========================================

# External APIs
WEATHER_API_KEY=your_weather_api_key
CURRENCY_API_KEY=your_currency_api_key

# ========================================
# Feature Flags
# ========================================

# Enable/Disable Features
ENABLE_WHATSAPP_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_ANALYTICS=true
ENABLE_REFERRAL_PROGRAM=false
ENABLE_MULTI_STORE_SUPPORT=false

# ========================================
# Business Configuration
# ========================================

# Loyalty Program Settings
DEFAULT_POINTS_PER_RUPEE=1
MIN_PURCHASE_AMOUNT=10
POINTS_EXPIRY_DAYS=365
REFERRAL_BONUS_POINTS=50

# Store Settings
DEFAULT_CURRENCY=INR
TIMEZONE=Asia/Kolkata
BUSINESS_HOURS_START=09:00
BUSINESS_HOURS_END=21:00

# ========================================
# Testing Configuration
# ========================================

# Test Database
TEST_MONGODB_URI=mongodb://localhost:27017/localloyal_test

# Test WhatsApp (sandbox)
TEST_TWILIO_ACCOUNT_SID=ACtestxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TEST_TWILIO_AUTH_TOKEN=your_test_auth_token

# ========================================
# Deployment Configuration
# ========================================

# Vercel
VERCEL_ORG_ID=your_vercel_org_id
VERCEL_PROJECT_ID=your_vercel_project_id

# Render
RENDER_SERVICE_URL=https://your-service.onrender.com
RENDER_API_KEY=your_render_api_key

# Docker
DOCKER_REGISTRY=your-docker-registry
DOCKER_IMAGE_TAG=latest

# ========================================
# Monitoring & Health Checks
# ========================================

# Health Check Endpoints
HEALTH_CHECK_ENDPOINT=/health
METRICS_ENDPOINT=/metrics

# Monitoring Services
NEW_RELIC_LICENSE_KEY=your_new_relic_license_key
DATADOG_API_KEY=your_datadog_api_key

# ========================================
# Backup Configuration
# ========================================

# Database Backup
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=backups/

# ========================================
# Security Headers
# ========================================

# Content Security Policy
CSP_DEFAULT_SRC=self
CSP_SCRIPT_SRC=self https://vercel.app
CSP_STYLE_SRC=self https://fonts.googleapis.com

# ========================================
# Localization
# ========================================

# Supported Languages
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,hi,gu,ta,te,ml,pa,bn,mr,kn,or

# Currency Formatting
CURRENCY_SYMBOL=₹
CURRENCY_DECIMAL_PLACES=2

# ========================================
# Third-party Integrations
# ========================================

# Google Services
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Facebook (if using)
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# ========================================
# Performance Optimization
# ========================================

# Caching
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# Database Connection
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_CONNECTION_TIMEOUT=30000

# ========================================
# Legal & Compliance
# ========================================

# GDPR Compliance
GDPR_COMPLIANCE=true
DATA_RETENTION_DAYS=2555

# Terms & Privacy
PRIVACY_POLICY_URL=https://your-app.vercel.app/privacy
TERMS_OF_SERVICE_URL=https://your-app.vercel.app/terms

# ========================================
# Development Tools
# ========================================

# Hot Reload
HOT_RELOAD=true
LIVE_RELOAD_PORT=8080

# Debug Tools
ENABLE_FLUTTER_INSPECTOR=true
ENABLE_DEBUG_CONSOLE=true

# ========================================
# Migration Scripts
# ========================================

# Database Migration
MIGRATION_AUTO_RUN=true
MIGRATION_TIMEOUT=300000

# Seed Data
SEED_DEFAULT_DATA=true
SEED_SAMPLE_CUSTOMERS=false

# ========================================
# API Rate Limiting
# ========================================

# Per-endpoint limits
AUTH_RATE_LIMIT=5
TRANSACTION_RATE_LIMIT=100
NOTIFICATION_RATE_LIMIT=50

# ========================================
# Error Handling
# ========================================

# Error Reporting
ERROR_WEBHOOK_URL=https://your-webhook-url.com/errors
ERROR_EMAIL_ERRORS=errors@your-company.com

# ========================================
# Custom Business Logic
# ========================================

# Reward Rules
REWARD_RULE_SPEND_100_GET_10=true
REWARD_RULE_VISIT_5_GET_COFFEE=true
REWARD_RULE_BIRTHDAY_BONUS=true

# Notification Preferences
NOTIFICATION_WELCOME=true
NOTIFICATION_POINTS_EARNED=true
NOTIFICATION_REWARD_UNLOCKED=true
NOTIFICATION_SPECIAL_OFFERS=false

# ========================================
# IMPORTANT NOTES
# ========================================

# 1. Replace all placeholder values with actual values
# 2. Never commit .env file to version control
# 3. Use different values for development and production
# 4. Keep sensitive keys secure and rotate regularly
# 5. Test all integrations before going to production
# 6. Monitor API usage and costs regularly

# ========================================
# Quick Setup Commands
# ========================================

# Copy this file to .env
# cp .env.example .env

# Edit the .env file with your actual values
# nano .env

# Test configuration
# npm run test:config

# Start development server
# npm run dev
